ition",name:{kind:"Name",value:"IntegrityCourseraProctoringSettings"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Integrity_CourseraProctoringSettings"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"enabled"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"configuration"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"primaryCameraConfig"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"cameraStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"recordingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"monitoringStatus"},arguments:[],directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"secondaryCameraConfig"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"cameraStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"recordingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"monitoringStatus"},arguments:[],directives:[]}]}}]}}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"IntegrityVivaExamSettings"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Integrity_VivaExamSettings"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"status"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"IntegritySession"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Session_Session"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"isPrivate"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"AcademicIntegritySettings"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Integrity_IntegritySettings"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"attemptId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"session"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegritySession"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"honorlockSettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegrityHonorlockSettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"lockingBrowserSettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegrityLockingBrowserSettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"autoProctorSettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegrityAutoProctorSettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"courseraProctoringSettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegrityCourseraProctoringSettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"vivaExamSettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IntegrityVivaExamSettings"},directives:[]}]}}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"Assignment"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_Assignment"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"passingFraction"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"assignmentType"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"assignmentGradingType"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"gradeSelectionStrategy"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"requiredMobileFeatures"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"learnerFeedbackVisibility"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"SlackIntegrationMetadata"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_SlackIntegrationMetadata"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"slackGroupId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackTeamId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackTeamDomain"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"SlackProfile"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_SlackProfile"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"slackTeamId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackUserId"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackName"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"deletedOrInactive"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"UserProfile"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_UserProfile"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"email"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"fullName"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"photoUrl"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackProfile"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"SlackProfile"},directives:[]}]}}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"TeamSubmitter"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_TeamSubmitter"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"name"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"teamActivityDescription"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"slackIntegrationMetadata"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"SlackIntegrationMetadata"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"memberProfiles"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"UserProfile"},directives:[]}]}}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"IndividualSubmitter"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_IndividualSubmitter"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"id"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"QueryStateSuccess"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_SubmissionState"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"allowedAction"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"assignment"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"Assignment"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"integritySettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"AcademicIntegritySettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"submitter"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IndividualSubmitter"},directives:[]},{kind:"FragmentSpread",name:{kind:"Name",value:"TeamSubmitter"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"attempts"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"Attempts"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"feedback"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",alias:{kind:"Name",value:"feedbackId"},name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"outcome"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"OverallOutcome"},directives:[]}]}}]}},{kind:"Field",name:{kind:"Name",value:"outcome"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"AssignmentOutcome"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"skillsVerifiedAt"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"gradingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"manualGradingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"warnings"},arguments:[],directives:[]}]}},{kind:"OperationDefinition",operation:"query",name:{kind:"Name",value:"QueryState"},variableDefinitions:[{kind:"VariableDefinition",variable:{kind:"Variable",name:{kind:"Name",value:"courseId"}},type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"ID"}}},directives:[]},{kind:"VariableDefinition",variable:{kind:"Variable",name:{kind:"Name",value:"itemId"}},type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"ID"}}},directives:[]}],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"SubmissionState"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"queryState"},arguments:[{kind:"Argument",name:{kind:"Name",value:"courseId"},value:{kind:"Variable",name:{kind:"Name",value:"courseId"}}},{kind:"Argument",name:{kind:"Name",value:"itemId"},value:{kind:"Variable",name:{kind:"Name",value:"itemId"}}}],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"InlineFragment",typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_QueryStateFailure"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"QueryStateFailure"},directives:[]}]}},{kind:"InlineFragment",typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_SubmissionState"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"QueryStateSuccess"},directives:[]}]}}]}}]}}]}}],loc:{start:0,end:10925}};n.loc.source={body:'#import "./AssignmentFragments.graphql"\n#import "./PartFragments.graphql"\n\n# To avoid issues with Apollo caching, we alias many `id` fields to use a different field name other than id when the\n# __typename + ID combination is not unique across all instances of the type.\n# An option ID can be exactly the same across different questions (e.g. if a question was duplicated), and the 2\n# unrelated options with the same ID must not be considered the same object in the Apollo cache.\n# If no `id` or `_id` field exists on an object (e.g. due to aliasing id to a different name), Apollo will cache the\n# object as part of the parent object instead of its own unique cache entry, which is what we want in many cases.\n\nfragment CheckboxQuestion on Submission_CheckboxQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  checkboxResponse: response {\n    chosen\n  }\n}\n\nfragment CheckboxReflectQuestion on Submission_CheckboxReflectQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  checkboxReflectResponse: response {\n    chosen\n  }\n}\n\nfragment CodeExpressionQuestion on Submission_CodeExpressionQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    codeLanguage\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n    replEvaluatorId\n    starterCode {\n      code\n    }\n  }\n  codeExpressionResponse: response {\n    answer {\n      code\n    }\n  }\n}\n\nfragment FileUploadQuestion on Submission_FileUploadQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    allowedFiles\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  fileUploadResponse: response {\n    caption\n    fileUrl\n    title\n  }\n}\n\nfragment MathQuestion on Submission_MathQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  mathResponse: response {\n    answer\n  }\n}\n\nfragment MultipleChoiceQuestion on Submission_MultipleChoiceQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  multipleChoiceResponse: response {\n    chosen\n  }\n}\n\nfragment MultipleChoiceReflectQuestion on Submission_MultipleChoiceReflectQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  multipleChoiceReflectResponse: response {\n    chosen\n  }\n}\n\nfragment MultipleChoiceFillableBlank on Submission_MultipleChoiceFillableBlank {\n  fillableBlankId: id\n  answerOptions {\n    ...Option\n  }\n}\n\nfragment MultipleChoiceFillableBlankResponse on Submission_MultipleChoiceFillableBlankResponse {\n  responseId: id\n  optionId\n}\n\nfragment MultipleFillableBlanksResponse on Submission_MultipleFillableBlanksQuestionResponse {\n  responses {\n    ...MultipleChoiceFillableBlankResponse\n  }\n}\n\nfragment MultipleFillableBlanksQuestion on Submission_MultipleFillableBlanksQuestion {\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n    fillableBlanks {\n      ...MultipleChoiceFillableBlank\n    }\n  }\n  multipleFillableBlanksResponse: response {\n    ...MultipleFillableBlanksResponse\n  }\n  gradeSettings {\n    maxScore\n  }\n}\n\nfragment NumericQuestion on Submission_NumericQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  numericResponse: response {\n    answer\n  }\n}\n\nfragment OffPlatformQuestion on Submission_OffPlatformQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n}\n\nfragment PlainTextQuestion on Submission_PlainTextQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  plainTextResponse: response {\n    plainText\n  }\n}\n\nfragment RegexQuestion on Submission_RegexQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  regexResponse: response {\n    answer\n  }\n}\n\nfragment RichTextQuestion on Submission_RichTextQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  richTextResponse: response {\n    richText {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n}\n\nfragment TextExactMatchQuestion on Submission_TextExactMatchQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  textExactMatchResponse: response {\n    answer\n  }\n}\n\nfragment TextReflectQuestion on Submission_TextReflectQuestion {\n  gradeSettings {\n    maxScore\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  textReflectResponse: response {\n    answer\n  }\n}\n\nfragment UrlQuestion on Submission_UrlQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  urlResponse: response {\n    caption\n    title\n    url\n  }\n}\n\nfragment WidgetQuestion on Submission_WidgetQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n    widgetSessionId\n  }\n  widgetResponse: response {\n    answer\n  }\n}\n\nfragment SubmissionPart on Submission_SubmissionPart {\n  ...CheckboxQuestion\n  ...CheckboxReflectQuestion\n  ...CodeExpressionQuestion\n  ...FileUploadQuestion\n  ...MathQuestion\n  ...MultipleChoiceQuestion\n  ...MultipleChoiceReflectQuestion\n  ...MultipleFillableBlanksQuestion\n  ...NumericQuestion\n  ...OffPlatformQuestion\n  ...PlainTextQuestion\n  ...RegexQuestion\n  ...RichTextQuestion\n  ...TextBlock\n  ...TextExactMatchQuestion\n  ...TextReflectQuestion\n  ...UrlQuestion\n  ...WidgetQuestion\n}\n\nfragment Submission on Submission_Submission {\n  id\n  parts {\n    ...SubmissionPart\n  }\n  instructions {\n    ...SubmissionInstructions\n  }\n  lastSavedAt\n}\n\nfragment InProgressAttempt on Submission_InProgressAttempt {\n  id\n  allowedDuration\n  draft {\n    ...Submission\n  }\n  autoSubmissionRequired\n  remainingDuration\n  startedTime\n  submissionsAllowed\n  submissionsMade\n  submissionsRemaining\n}\n\nfragment LastSubmission on Submission_LastSubmission {\n  id\n  submission {\n    ...Submission\n  }\n  submittedAt\n}\n\nfragment NextAttempt on Submission_NextAttempt {\n  allowedDuration\n  submissionsAllowed\n}\n\nfragment SubmissionRateLimiterConfig on Submission_RateLimiterConfig {\n  attemptsRemainingIncreasesAt\n  maxPerInterval\n  timeIntervalDuration\n}\n\nfragment Attempts on Submission_Attempts {\n  lastSubmission {\n    ...LastSubmission\n  }\n  nextAttempt {\n    ...NextAttempt\n  }\n  attemptsAllowed\n  attemptsMade\n  attemptsRemaining\n  inProgressAttempt {\n    ...InProgressAttempt\n  }\n  rateLimiterConfig {\n    ...SubmissionRateLimiterConfig\n  }\n}\n\nfragment AssignmentOutcome on Submission_AssignmentOutcome {\n  earnedGrade\n  gradeOverride {\n    original\n    override\n  }\n  isPassed\n  latePenaltyRatio\n}\n\nfragment IntegrityAutoProctorSettings on Integrity_AutoProctorSettings {\n  enabled\n  clientId\n  hashedAttemptId\n}\n\nfragment IntegrityHonorlockSettings on Integrity_HonorlockSettings {\n  enabled\n}\n\nfragment IntegrityLockingBrowserSettings on Integrity_LockingBrowserSettings {\n  enabled\n  enabledForCurrentUser\n}\n\nfragment IntegrityCourseraProctoringSettings on Integrity_CourseraProctoringSettings {\n  enabled\n  configuration {\n    primaryCameraConfig {\n      cameraStatus\n      recordingStatus\n      monitoringStatus\n    }\n    secondaryCameraConfig {\n      cameraStatus\n      recordingStatus\n      monitoringStatus\n    }\n  }\n}\n\nfragment IntegrityVivaExamSettings on Integrity_VivaExamSettings {\n  status\n}\n\nfragment IntegritySession on Session_Session {\n  id\n  isPrivate\n}\n\nfragment AcademicIntegritySettings on Integrity_IntegritySettings {\n  attemptId\n  session {\n    ...IntegritySession\n  }\n  honorlockSettings {\n    ...IntegrityHonorlockSettings\n  }\n  lockingBrowserSettings {\n    ...IntegrityLockingBrowserSettings\n  }\n  autoProctorSettings {\n    ...IntegrityAutoProctorSettings\n  }\n  courseraProctoringSettings {\n    ...IntegrityCourseraProctoringSettings\n  }\n  vivaExamSettings {\n    ...IntegrityVivaExamSettings\n  }\n}\n\nfragment Assignment on Submission_Assignment {\n  id\n  passingFraction\n  assignmentType\n  assignmentGradingType\n  gradeSelectionStrategy\n  requiredMobileFeatures\n  learnerFeedbackVisibility\n}\n\nfragment SlackIntegrationMetadata on Submission_SlackIntegrationMetadata {\n  slackGroupId\n  slackTeamId\n  slackTeamDomain\n}\n\nfragment SlackProfile on Submission_SlackProfile {\n  slackTeamId\n  slackUserId\n  slackName\n  deletedOrInactive\n}\n\nfragment UserProfile on Submission_UserProfile {\n  id\n  email\n  fullName\n  photoUrl\n  slackProfile {\n    ...SlackProfile\n  }\n}\n\nfragment TeamSubmitter on Submission_TeamSubmitter {\n  id\n  name\n  teamActivityDescription\n  slackIntegrationMetadata {\n    ...SlackIntegrationMetadata\n  }\n  memberProfiles {\n    ...UserProfile\n  }\n}\n\nfragment IndividualSubmitter on Submission_IndividualSubmitter {\n  id\n}\n\nfragment QueryStateSuccess on Submission_SubmissionState {\n  allowedAction\n  assignment {\n    ...Assignment\n  }\n  integritySettings {\n    ...Academ